{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "build:local": "cross-env NEXT_PUBLIC_TINA_CLIENT_ID= TINA_TOKEN= next build",
    "dev:local": "cross-env NEXT_PUBLIC_TINA_CLIENT_ID= TINA_TOKEN= tinacms dev -c \"next dev\"",
    "start": "tinacms build && next start",
    "prod": "cross-env NODE_ENV=production npm run start",
    "lint": "eslint",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@tinacms/cli": "^2.0.2",
    "cookies-next": "^6.1.0",
    "next": "^16.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "tailwindcss": "^4",
    "tinacms": "^3.0.2",
    "vitest": "^4.0.15",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "jsdom": "^27.2.0",
    "next-sitemap": "^4.2.3",
    "typescript": "^5"
  },
  "overrides": {
    "dompurify": "^3.2.4",
    "jsonpath-plus": "^10.2.1",
    "esbuild": "0.24.2",
    "mermaid": "^11.4.1",
    "vite": "4.5.9"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not IE 11"
  ]
}
