<IfModule mod_rewrite.c>
RewriteEngine On
# Serve extensionless URLs by falling back to corresponding .html if it exists
# e.g. /polityka-prywatnosci -> /polityka-prywatnosci.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
</IfModule>
